{
  "name": "siclaw",
  "version": "0.1.4",
  "description": "AI-powered SRE copilot for Kubernetes diagnostics via natural language",
  "type": "module",
  "bin": {
    "siclaw": "./siclaw.mjs"
  },
  "files": [
    "dist/",
    "portal-web/dist/",
    "siclaw.mjs",
    "skills/",
    "settings.example.json"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scitix/siclaw.git"
  },
  "homepage": "https://github.com/scitix/siclaw#readme",
  "bugs": {
    "url": "https://github.com/scitix/siclaw/issues"
  },
  "keywords": [
    "sre",
    "kubernetes",
    "k8s",
    "ai",
    "copilot",
    "diagnostics",
    "claude",
    "agent"
  ],
  "engines": {
    "node": ">=22.19.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@clack/prompts": "^1.1.0",
    "@earendil-works/pi-agent-core": "^0.78.1",
    "@earendil-works/pi-coding-agent": "0.78.1",
    "@earendil-works/pi-tui": "^0.78.1",
    "@kubernetes/client-node": "^1.4.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@sinclair/typebox": "^0.34.0",
    "adm-zip": "^0.5.17",
    "diff": "^8.0.3",
    "glob": "^13.0.6",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "markdown-it": "^14.1.0",
    "mysql2": "^3.22.0",
    "node-forge": "^1.3.3",
    "prom-client": "^15.1.3",
    "sqlite-vec": "^0.1.7-alpha.2",
    "ssh2": "^1.17.0",
    "tar": "^7.5.15",
    "ws": "^8.18.0"
  },
  "optionalDependencies": {
    "@larksuiteoapi/node-sdk": "^1.56.1",
    "@slack/bolt": "^4.6.0",
    "@slack/web-api": "^7.14.1",
    "dingtalk-stream-sdk-nodejs": "^2.0.4",
    "discord.js": "^14.16.0",
    "grammy": "^1.41.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/diff": "^7.0.2",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.19.8",
    "@types/node-forge": "^1.3.14",
    "@types/react-router-dom": "^5.3.3",
    "@types/ssh2": "^1.15.5",
    "@types/ws": "^8.5.0",
    "autoprefixer": "^10.4.24",
    "clsx": "^2.1.1",
    "framer-motion": "^12.31.0",
    "lucide-react": "^0.563.0",
    "postcss": "^8.5.6",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  },
  "scripts": {
    "build": "tsc",
    "build:web": "cd portal-web && npm run build",
    "build:all": "npm run build && npm run build:web",
    "prepublishOnly": "npm run build && cd portal-web && npm ci && npm run build",
    "dev": "tsx src/cli-main.ts",
    "dev:runtime": "tsx src/gateway-main.ts",
    "dev:agentbox": "tsx src/agentbox-main.ts",
    "dev:portal": "tsx src/portal-main.ts",
    "start": "node siclaw-tui.mjs",
    "start:runtime": "node dist/gateway-main.js",
    "start:agentbox": "node dist/agentbox-main.js",
    "start:portal": "node dist/portal-main.js",
    "test": "vitest run",
    "smoke:dp-live": "node scripts/smoke/dp-live-checkpoint.mjs",
    "smoke:delegate": "node scripts/smoke/real-delegate.mjs",
    "smoke:delegate-batch": "node scripts/smoke/real-delegate-batch.mjs",
    "smoke:delegate-async": "node scripts/smoke/real-delegate-async.mjs",
    "smoke:delegate-ui": "node scripts/smoke/real-delegate-ui.mjs",
    "smoke:delegate-batch-ui": "node scripts/smoke/real-delegate-batch-ui.mjs",
    "smoke:agentbox-routing": "node scripts/smoke/agentbox-model-routing.mjs",
    "docker:build:runtime": "docker build -f Dockerfile.runtime -t siclaw/siclaw-runtime:latest .",
    "docker:build:portal": "docker build -f Dockerfile.portal -t siclaw/siclaw-portal:latest .",
    "docker:build:agentbox": "docker build -f Dockerfile.agentbox -t siclaw/siclaw-agentbox:latest .",
    "docker:build:ocr": "docker build -f Dockerfile.ocr -t siclaw/siclaw-ocr:latest .",
    "docker:push:runtime": "docker push siclaw/siclaw-runtime:latest",
    "docker:push:ocr": "docker push siclaw/siclaw-ocr:latest",
    "docker:push:agentbox": "docker push siclaw/siclaw-agentbox:latest"
  }
}
